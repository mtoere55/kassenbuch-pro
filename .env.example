# Future server-only configuration. Never commit real secrets.
DATABASE_URL=
DOCUMENT_STORAGE_BUCKET=
DOCUMENT_STORAGE_ENDPOINT=
OPEN_BANKING_PROVIDER=
OPEN_BANKING_CLIENT_ID=
OPEN_BANKING_CLIENT_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
